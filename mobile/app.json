{
  "expo": {
    "name": "Kron",
    "slug": "kron-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "kron",
    "backgroundColor": "#0f0b15",
    "primaryColor": "#f59e0b",
    "description": "The AI calendar that rules your time. Voice assistant, smart scheduling, focus mode.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0b15"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#f59e0b",
      "iosDisplayInForeground": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kron.calendar",
      "buildNumber": "1",
      "backgroundColor": "#0f0b15",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Kron needs microphone access for voice commands (Hey Kron).",
        "NSSpeechRecognitionUsageDescription": "Kron uses speech recognition to transcribe your voice commands.",
        "NSCalendarsUsageDescription": "Kron can sync with your Apple Calendar to show all your events in one place.",
        "NSRemindersUsageDescription": "Kron can import your reminders so they appear alongside your events.",
        "UIBackgroundModes": ["fetch", "processing"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0b15"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.kron.calendar",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Kron",
      "themeColor": "#0f0b15",
      "backgroundColor": "#0f0b15"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "Kron can import events from your Apple/Google calendar so they appear alongside your schedule."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Kron needs microphone access for voice commands."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f59e0b",
          "defaultChannel": "default"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"]
  }
}
